<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_shape"
    android:padding="12dp">

    <!-- Top Header: Centered Month Title overlaying invisible left/right click-switch touch targets -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_month_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="August 2024"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:gravity="center"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <View
                android:id="@+id/btn_prev_month"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/btn_next_month"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </FrameLayout>

    <!-- Week Days Headers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        <TextView android:id="@+id/week_header_0" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Mon" android:textSize="12sp" android:textColor="#666666" android:gravity="center" />
        <TextView android:id="@+id/week_header_1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Tue" android:textSize="12sp" android:textColor="#666666" android:gravity="center" />
        <TextView android:id="@+id/week_header_2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Wed" android:textSize="12sp" android:textColor="#666666" android:gravity="center" />
        <TextView android:id="@+id/week_header_3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Thu" android:textSize="12sp" android:textColor="#666666" android:gravity="center" />
        <TextView android:id="@+id/week_header_4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Fri" android:textSize="12sp" android:textColor="#666666" android:gravity="center" />
        <TextView android:id="@+id/week_header_5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Sat" android:textSize="12sp" android:textColor="#666666" android:gravity="center" />
        <TextView android:id="@+id/week_header_6" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Sun" android:textSize="12sp" android:textColor="#FF3B30" android:gravity="center" />
    </LinearLayout>

    <!-- Grid of 6 rows x 7 days -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Row 0 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:id="@+id/cell_0" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_6" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#FF3B30" />
        </LinearLayout>

        <!-- Row 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:id="@+id/cell_7" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_8" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_9" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_10" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_11" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_12" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_13" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#FF3B30" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:id="@+id/cell_14" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_15" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_16" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_17" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_18" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_19" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_20" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#FF3B30" />
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:id="@+id/cell_21" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_22" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_23" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_24" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_25" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_26" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_27" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#FF3B30" />
        </LinearLayout>

        <!-- Row 4 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:id="@+id/cell_28" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_29" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_30" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_31" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_32" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_33" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_34" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#FF3B30" />
        </LinearLayout>

        <!-- Row 5 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:id="@+id/cell_35" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_36" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_37" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_38" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_39" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_40" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#222222" />
            <TextView android:id="@+id/cell_41" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:gravity="center" android:textSize="14sp" android:textColor="#FF3B30" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
